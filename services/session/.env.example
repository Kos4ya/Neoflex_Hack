# services/session/.env
# Service
SERVICE_NAME=session-service
PORT=8002
ENVIRONMENT=development
DEBUG=true

# Database (локальный PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5433/session_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=my-super-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Service URLs (для внутренних вызовов)
USER_SERVICE_URL=http://localhost:8001
VACANCIES_SERVICE_URL=http://localhost:8003

# Internal API Key
INTERNAL_API_KEY=your-internal-api-key-change-me

# Security
BCRYPT_ROUNDS=12